EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# PostHog product analytics (US Cloud). Leave unset to disable analytics entirely.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry crash reporting. Leave unset to disable crash reporting entirely.
EXPO_PUBLIC_SENTRY_DSN=

# Sentry source-map upload — EAS BUILD ONLY (set as EAS secrets, NOT bundled):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
